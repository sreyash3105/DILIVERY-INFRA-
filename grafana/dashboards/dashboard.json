            "type": "prometheus",
            "uid": "Prometheus"
          },
          "editorMode": "code",
          "expr": "sum(websocket_connections_active) by (endpoint)",
          "legendFormat": "{{endpoint}}",
          "range": true,
          "refId": "A"
