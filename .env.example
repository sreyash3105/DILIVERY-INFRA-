# ============================================================
# Delivery Infrastructure Platform — Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual values.
# The .env file is gitignored and should NEVER be committed.
#
#   cp .env.example .env
# ============================================================

# ----- PostgreSQL -----
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password_here
DATABASE_URL=postgresql+asyncpg://postgres:your_postgres_password_here@postgres:5432/delivery_platform

# ----- Redis -----
REDIS_URL=redis://redis:6379/0

# ----- Grafana -----
GRAFANA_ADMIN_PASSWORD=your_grafana_password_here

# ----- Optional: SendGrid Email Notifications -----
# Leave blank to use the console-log mock fallback.
SENDGRID_API_KEY=

# ----- Optional: Firebase Push Notifications -----
# Provide the path to your Firebase service account JSON file.
# Leave blank to use the console-log mock fallback.
FIREBASE_CREDENTIALS_PATH=
